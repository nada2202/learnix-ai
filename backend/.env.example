# Comma-separated keys. The backend rotates on rate-limit or invalid-key errors.
GROQ_API_KEYS=gsk_your_first_key,gsk_your_second_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,meta-llama/llama-4-scout-17b-16e-instruct,qwen/qwen3-32b
GROQ_TIMEOUT_SECONDS=10
GROQ_TEMPORARY_FAILURE_LIMIT=2
SECRET_KEY=change-me
JWT_SECRET=change-me-too
JWT_EXPIRES_HOURS=8
RESET_TOKEN_EXPIRES_MINUTES=30
FRONTEND_URL=http://localhost:5173
FLASK_PORT=5001
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ai_learning_platform
SEED_DEFAULT_PASSWORD=Learnix123!
