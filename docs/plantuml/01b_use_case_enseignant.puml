@startuml
title Diagramme de cas d'utilisation - Enseignant

left to right direction
skinparam monochrome true
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor Enseignant as Teacher
actor "Enseignant invite" as GuestTeacher

rectangle "Learnix AI - Espace enseignant" {
  usecase "Demander un rattachement\na un etablissement" as UCRequest
  usecase "Consulter son perimetre\nd'enseignement" as UCScope
  usecase "Gerer les cours" as UCCourses
  usecase "Creer et gerer les quiz" as UCQuizzes
  usecase "Consulter les resultats\ndes etudiants" as UCResults
  usecase "Definir les disponibilites" as UCAvailability
}

Teacher --> UCRequest
Teacher --> UCScope
Teacher --> UCCourses
Teacher --> UCQuizzes
Teacher --> UCResults
Teacher --> UCAvailability

GuestTeacher --> UCRequest
GuestTeacher --> UCScope
GuestTeacher --> UCCourses
GuestTeacher --> UCQuizzes
GuestTeacher --> UCAvailability
@enduml
